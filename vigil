#!/usr/bin/env bash
#
# vigil — one-stop CLI for the Vigil uptime/status-page app (Laravel + Sail).
# Thin wrapper over Laravel Sail so day-to-day work is `./vigil <cmd>`, never raw
# docker compose. Run `./vigil help` for the command list.
#
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$(realpath "$0")")" && pwd)"
SAIL="$ROOT_DIR/vendor/bin/sail"
cd "$ROOT_DIR"

c_green='\033[0;32m'; c_yellow='\033[1;33m'; c_dim='\033[2m'; c_off='\033[0m'
say() { echo -e "${c_green}==>${c_off} $*"; }
warn() { echo -e "${c_yellow}!! ${c_off} $*"; }

ensure_env() {
  if [[ ! -f "$ROOT_DIR/.env" ]]; then
    say "creating .env from .env.example"
    cp "$ROOT_DIR/.env.example" "$ROOT_DIR/.env"
  fi
}

sail() {
  if [[ ! -x "$SAIL" ]]; then
    warn "Sail not installed yet — run './vigil init' first."
    exit 1
  fi
  "$SAIL" "$@"
}

cmd_init() {
  ensure_env
  say "building + starting the Sail stack (app, postgres, redis, horizon, scheduler)..."
  "$SAIL" up -d --build
  say "waiting for the database..."
  until "$SAIL" exec -T pgsql pg_isready -q 2>/dev/null; do sleep 1; done
  if ! grep -q '^APP_KEY=base64' "$ROOT_DIR/.env"; then
    say "generating APP_KEY..."
    "$SAIL" artisan key:generate
  fi
  say "running migrations..."
  "$SAIL" artisan migrate --force
  say "installing + building frontend assets..."
  "$SAIL" npm install
  "$SAIL" npm run build
  say "Vigil is up. Dashboard: http://localhost  ·  Horizon: http://localhost/horizon"
  echo -e "${c_dim}Sign up, add a monitor, then watch http://localhost/status/{your-slug}${c_off}"
}

cmd_start() { ensure_env; say "starting containers..."; "$SAIL" up -d; }
cmd_stop()  { say "stopping containers..."; "$SAIL" down; }
cmd_test()  { say "running the test suite (phpunit)..."; sail artisan test "$@"; }
cmd_lint()  { say "linting with Pint..."; sail pint "$@"; }
cmd_queue() { say "opening Horizon (Ctrl-C to detach the log)..."; sail artisan horizon "$@"; }
cmd_shell() { sail shell; }
cmd_logs()  { sail logs -f "$@"; }
cmd_npm()   { sail npm "$@"; }
cmd_tick()  { say "dispatching one round of due checks..."; sail artisan monitors:tick; }

cmd_artisan() { sail artisan "$@"; }

usage() {
  cat <<EOF
vigil — Laravel + Sail CLI for the Vigil status-page app

Usage: ./vigil <command> [args]

  init             Build & start the full stack, migrate, seed keys, build assets
  start            Start containers (no rebuild)
  stop             Stop and remove containers
  test [args]      Run the PHPUnit suite (passes args through, e.g. --filter=Monitoring)
  lint [args]      Run Laravel Pint
  artisan <...>    Run any artisan command inside the app container
  queue            Run Horizon (queue worker + dashboard backend)
  tick             Dispatch one round of due monitor checks by hand
  npm <...>        Run npm inside the app container (e.g. ./vigil npm run dev)
  shell            Open a shell in the app container
  logs [svc]       Tail container logs
  help             Show this message
EOF
}

main() {
  local cmd="${1:-help}"; shift || true
  case "$cmd" in
    init)    cmd_init "$@" ;;
    start|up) cmd_start "$@" ;;
    stop|down) cmd_stop "$@" ;;
    test)    cmd_test "$@" ;;
    lint)    cmd_lint "$@" ;;
    artisan) cmd_artisan "$@" ;;
    queue|horizon) cmd_queue "$@" ;;
    tick)    cmd_tick "$@" ;;
    npm)     cmd_npm "$@" ;;
    shell|bash) cmd_shell "$@" ;;
    logs)    cmd_logs "$@" ;;
    help|-h|--help) usage ;;
    *) warn "unknown command: $cmd"; echo; usage; exit 1 ;;
  esac
}

main "$@"
